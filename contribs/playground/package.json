{
  "name": "gno-playground",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm -C app dev",
    "build": "pnpm build:packages && pnpm build:app",
    "build:app": "pnpm -C app build",
    "build:packages": "pnpm -r -C packages build",
    "lint": "pnpm -C app lint",
    "preview": "pnpm -C app preview"
  },
  "packageManager": "pnpm@10.15.1",
  "pnpm": {
    "overrides": {
      "react": "18.3.1",
      "@swc/core": "1.11.24"
    }
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "unenv": "^2.0.0-rc.17"
  }
}
