// 01_reset_valset.gno.tmpl — MsgRun body that runs AT THE END of the
// hardfork replay (post-history) to update r/sys/validators/v2 so the
// in-gno valset matches the new GenesisDoc.Validators.
//
// Why: tm2 consensus uses GenesisDoc.Validators (which `gnogenesis fork`
// rewrites in the output genesis), but r/sys/validators/v2 still holds
// the ORIGINAL gnoland1 valset from govdao_prop1. Without this migration,
// queries against the realm return stale data and any govDAO proposal
// that touches the valset via the realm would be working against a ghost
// of the pre-fork world.
//
// Drift resilience: the build.sh RPC snapshot of v2.GetValidators() is
// taken pre-assembly; by the time this proposal executes during replay,
// v2 state may have drifted (e.g. historical txs that were skipped,
// cascading changes from other migrations). The callback therefore
// consults live v2 state at execution time via valr.IsValidator and
// only emits zero-voting-power entries for validators that are actually
// present. Without this check, r/sys/validators/v2.removeValidator
// panics "validator doesn't exist" on the first missing entry, aborting
// the whole proposal and leaving the valset unreconciled.
//
// Placeholders (replaced by migrations/build.sh before signing):
//   OLD_ADDRESSES_GO   placeholder — candidate addresses to zero-voting-power
//                       (filtered at exec time against live v2 state)
//   NEW_VALIDATORS_GO  placeholder — full entries for the post-fork validator(s)
//
// Caller: a govDAO T1 member (see build.sh CALLER env). Sig verify is
// skipped at genesis-replay via --skip-genesis-sig-verification.
package main

import (
	"gno.land/p/sys/validators"
	"gno.land/r/gov/dao"
	valr "gno.land/r/sys/validators/v2"
)

func main() {
	req := valr.NewPropRequest(
		func() []validators.Validator {
			// Candidate pre-fork validators to remove. Filtered below so
			// we only emit entries for ones actually present in v2; a
			// single missing address would otherwise abort the proposal.
			// Note: `address` is the gno-builtin bech32 type; no std
			// import needed (matches the pattern used by 04_withdraw_*).
			candidates := []address{
				{{OLD_ADDRESSES_GO}}
			}

			out := []validators.Validator{}
			for _, addr := range candidates {
				if valr.IsValidator(addr) {
					out = append(out, validators.Validator{Address: addr, VotingPower: 0})
				}
			}

			// Add post-fork validators unconditionally.
			out = append(out, []validators.Validator{
				{{NEW_VALIDATORS_GO}}
			}...)

			return out
		},
		"Hardfork: reset validator set",
		"Reconcile r/sys/validators/v2 with the new GenesisDoc.Validators "+
			"after the gnoland1 → gnoland-1 hardfork.",
	)

	id := dao.MustCreateProposal(cross, req)
	dao.MustVoteOnProposal(cross, dao.VoteRequest{Option: dao.YesVote, ProposalID: id})
	dao.ExecuteProposal(cross, id)
}
