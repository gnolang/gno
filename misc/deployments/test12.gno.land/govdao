#!/usr/bin/env bash
# Wrapper for govdao-scripts on test12.
# Sets deployment-specific env vars and forwards to shared scripts.
#
# Usage:
#   ./govdao                          # list available commands
#   ./govdao add-validator ADDR KEY   # run a command
#   ./govdao rm-validator ADDR        # run a command
#
# Override defaults via env vars:
#   GNOKEY_NAME=other ./govdao rm-validator g1abc...
set -eo pipefail

SCRIPTS_DIR="$(cd "$(dirname "$0")/../../govdao-scripts" && pwd)"

# test12 defaults
export GNOKEY_NAME="${GNOKEY_NAME:-aeddi}"
export CHAIN_ID="${CHAIN_ID:-test12}"
export REMOTE="${REMOTE:-https://rpc.test12.gno.land:443}"

if [ $# -eq 0 ]; then
  echo "govdao — test12"
  echo ""
  echo "  chain-id: $CHAIN_ID"
  echo "  remote:   $REMOTE"
  echo "  key:      $GNOKEY_NAME"
  echo ""
  echo "commands:"
  for script in "$SCRIPTS_DIR"/*.sh; do
    name=$(basename "$script" .sh)
    desc=$(grep -m1 '^# [A-Z]' "$script" | sed 's/^# //')
    printf "  %-35s %s\n" "$name" "$desc"
  done
  exit 0
fi

CMD="$1"
shift

SCRIPT="$SCRIPTS_DIR/${CMD}.sh"
if [ ! -x "$SCRIPT" ]; then
  echo "error: unknown command '$CMD'" >&2
  echo "run '$0' without arguments to list available commands" >&2
  exit 1
fi

exec "$SCRIPT" "$@"
