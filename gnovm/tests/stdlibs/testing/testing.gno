// PB
// TODO: actually implement

type PB struct{}

func (pb *PB) Next() bool { panic("testing: PB.Next is unsupported in Gno") }

type InternalTest struct {
	Name  string
	F     testingFunc
	F_cur testingFunc_cur // (jae) Special case in gnovm/pkg/test.
	Cur   realm           // (jae) Ditto. This won't work except through gnovm/pkg/test.
}

type benchmarkFunc func(*B)

type benchmarkFunc_cur func(realm, *B) // Special case in gnovm/pkg/test.

type InternalBenchmark struct {
	Name  string
	F     benchmarkFunc
	F_cur benchmarkFunc_cur // Special case in gnovm/pkg/test.
	Cur   realm             // Ditto. This won't work except through gnovm/pkg/test.
}

// matchFilter ignores the partial flag
// we do not act on "prefix-only" matches.
func matchFilter(filter filterMatch, name string) bool {
	if filter == nil {
		return true
	}
	ok, _ := filter.matches(strings.Split(name, "/"))
	return ok
}

func (t *T) shouldRun(name string) bool { return matchFilter(t.runFilter, name) }

func RunTest(runFlag string, verbose bool, failfast bool, test InternalTest) (ret string) {
	t := &T{
		name:     test.Name,
		verbose:  verbose,
		failfast: failfast,
	}

	if runFlag != "" {
		t.runFilter = splitRegexp(runFlag)
	}

	tRunner(t, test.F, verbose)
	if !t.verbose && t.Failed() {
		// use printFailure to print output log of this
		// and/or any subtests that may have failed.
		t.printFailure()
	}

	report := t.report()
	return report.marshal()
}

// (jae) Special case in gnovm/pkg/test.
func runTest_cur(runFlag string, verbose bool, failfast bool, test InternalTest) (ret string) {
	t := &T{
		name:     test.Name,
		verbose:  verbose,
		failfast: failfast,
	}

	if runFlag != "" {
		t.runFilter = splitRegexp(runFlag)
	}

	tRunner_cur(t, test.F_cur, test.Cur, verbose)
	if !t.verbose && t.Failed() {
		// use printFailure to print output log of this
		// and/or any subtests that may have failed.
		t.printFailure()
	}

	report := t.report()
	return report.marshal()
}

func RunBenchmark(runFlag string, n int, verbose bool, benchmark InternalBenchmark) (ret string) {
	b := &B{
		N:       n,
		name:    benchmark.Name,
		verbose: verbose,
	}
	if runFlag != "" {
		b.runFilter = splitRegexp(runFlag)
	}

	bRunner(b, benchmark.F, verbose)
	if !b.verbose && b.Failed() {
		b.printFailure()
	}

	reports := BenchmarkReports{Reports: b.reports()}
	return reports.marshal()
}

// Special case in gnovm/pkg/test.
func runBenchmark_cur(runFlag string, n int, verbose bool, benchmark InternalBenchmark) (ret string) {
	b := &B{
		N:       n,
		name:    benchmark.Name,
		verbose: verbose,
	}
	if runFlag != "" {
		b.runFilter = splitRegexp(runFlag)
	}

	bRunner_cur(b, benchmark.F_cur, benchmark.Cur, verbose)
	if !b.verbose && b.Failed() {
		b.printFailure()
	}

	reports := BenchmarkReports{Reports: b.reports()}
	return reports.marshal()
}

func bRunner(b *B, fn benchmarkFunc, verbose bool) {
	if !b.shouldRun(b.name) {
		b.filtered = true
		return
	}
	b.StartTimer()
	defer func() {
		err, st := recoverWithStacktrace()
		switch err.(type) {
		case nil:
		case SkipErr:
		default:
			b.Fail()
			fmt.Fprintf(os.Stderr, "panic: %v\nStacktrace:\n%s\n", err, st)
		}

		b.StopTimer()
	}()

	fn(b)
}

func bRunner_cur(b *B, fn benchmarkFunc_cur, rlm realm, verbose bool) {
	if !b.shouldRun(b.name) {
		b.filtered = true
		return
	}
	b.StartTimer()
	defer func() {
		err, st := recoverWithStacktrace()
		switch err.(type) {
		case nil:
		case SkipErr:
		default:
			b.Fail()
			fmt.Fprintf(os.Stderr, "panic: %v\nStacktrace:\n%s\n", err, st)
		}

		b.StopTimer()
	}()

	fn(rlm, b)
}

func formatDur(dur int64) string {
	// XXX switch to FormatFloat after it's been added
	// 1 sec = 1e9 nsec
	// this gets us the "centiseconds" which is what we show in tests.
	dstr := strconv.Itoa(int(dur / 1e7))
	if len(dstr) < 3 {
		const pad = "000"
		dstr = pad[:3-len(dstr)] + dstr
	}
	return dstr[:len(dstr)-2] + "." + dstr[len(dstr)-2:] + "s"
}

// used to calculate execution times; only present in testing stdlibs
func unixNano() int64

// used to calculate deterministic benchmark cycle counts; only present in testing stdlibs
func cycleCount() int64

// used to read the deterministic gas counter shared by cycles, allocator, GC, and native
// functions; only present in testing stdlibs
func gasConsumed() int64

// used to calculate deterministic benchmark allocation bytes; only present in testing stdlibs
func allocBytes() int64

// used to calculate deterministic benchmark allocation counts; only present in testing stdlibs
func allocCount() int64

// recovers panics and returns their related stacktraces, as well
func recoverWithStacktrace() (interface{}, string)

// used to filter tests, we can't directly use regexp here due to a cyclic import; only present in testing stdlibs
func matchString(pat, str string) (bool, string)

func tRunner(t *T, fn testingFunc, verbose bool) {
	if !t.shouldRun(t.name) {
		return
	}

	start := unixNano()

	defer func() {
		err, st := recoverWithStacktrace()
		switch err.(type) {
		case nil:
		case SkipErr:
		default:
			t.Fail()
			fmt.Fprintf(os.Stderr, "panic: %v\nStacktrace:\n%s\n", err, st)
		}

		dur := unixNano() - start
		t.dur = formatDur(dur)

		if t.verbose {
			switch {
			case t.Failed():
				fmt.Fprintf(os.Stderr, "--- FAIL: %s (%s)\n", t.name, t.dur)
			case t.skipped:
				fmt.Fprintf(os.Stderr, "--- SKIP: %s (%s)\n", t.name, t.dur)
			case t.verbose:
				fmt.Fprintf(os.Stderr, "--- PASS: %s (%s)\n", t.name, t.dur)
			}
		}
	}()

	if verbose {
		fmt.Fprintf(os.Stderr, "=== RUN   %s\n", t.name)
	}

	fn(t)
}

func tRunner_cur(t *T, fn testingFunc_cur, next realm, verbose bool) {
	if !t.shouldRun(t.name) {
		return
	}

	start := unixNano()

	defer func() {
		err, st := recoverWithStacktrace()
		switch err.(type) {
		case nil:
		case SkipErr:
		default:
			t.Fail()
			fmt.Fprintf(os.Stderr, "panic: %v\nStacktrace:\n%s\n", err, st)
		}

		dur := unixNano() - start
		t.dur = formatDur(dur)

		if t.verbose {
			switch {
			case t.Failed():
				fmt.Fprintf(os.Stderr, "--- FAIL: %s (%s)\n", t.name, t.dur)
			case t.skipped:
				fmt.Fprintf(os.Stderr, "--- SKIP: %s (%s)\n", t.name, t.dur)
			case t.verbose:
				fmt.Fprintf(os.Stderr, "--- PASS: %s (%s)\n", t.name, t.dur)
			}
		}
	}()

	if verbose {
		fmt.Fprintf(os.Stderr, "=== RUN   %s\n", t.name)
	}

	// (jae) handled by gnovm/pkg/test and gnovm preprocessor.
	// Normally the first argument must be `cur` or `cross`,
	// but from this package it is possible to pass a realm
	// value without crossing.
	fn(next, t)
}
