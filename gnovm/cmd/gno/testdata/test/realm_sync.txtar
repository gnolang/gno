# Test Realm instruction updated

gno test -v . -update-golden-tests

! stdout .+ # stdout should be empty
stderr '=== RUN   ./x_filetest.gno'
stderr '--- PASS: ./x_filetest.gno \(elapsed: \d+\.\d\ds, gas: \d+\)'
stderr 'ok      \. 	\d+\.\d\ds'

cmp filetests/x_filetest.gno x_filetest.gno.golden

-- filetests/x_filetest.gno --
// PKGPATH: gno.land/r/xx
package xx

var x int

func main(cur realm) {
	x = 1
}

// Realm:
// xxx
-- x_filetest.gno.golden --
