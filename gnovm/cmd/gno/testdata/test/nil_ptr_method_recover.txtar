# recover().(error) on a nil pointer value method call returns the right error type and message

gno run .

-- main.gno --
package main

import "strings"

type T int

type I interface {
	F()
}

func (t T) F() {}

var (
	t *T
	i I = t
)

func main() {
	defer func() {
		got := recover().(error).Error()
		if !strings.Contains(got, "called using nil *T pointer") {
			panic("panicwrap error text " + got)
		}
	}()
	i.F()
}
