# gno test -gasprofile writes a pprof gas profile of the executed tests.
gno test -gasprofile=$WORK/gas.pprof .
stderr 'gas profile written to'
exists $WORK/gas.pprof

# -gasprofile is incompatible with parallel execution (the profiler is not
# concurrency-safe), so -p >1 is rejected.
! gno test -gasprofile=$WORK/gas2.pprof -p 2 .
stderr 'can only be used with -p 1'
! exists $WORK/gas2.pprof

-- gnomod.toml --
module = "gno.test/p/gasprof"
gno = "0.9"

-- lib.gno --
package gasprof

func Compute(n int) int {
	s := 0
	for i := 0; i < n; i++ {
		s += i
	}
	return s
}

-- lib_test.gno --
package gasprof

import "testing"

func TestCompute(t *testing.T) {
	if Compute(100) != 4950 {
		t.Fatal("wrong result")
	}
}
