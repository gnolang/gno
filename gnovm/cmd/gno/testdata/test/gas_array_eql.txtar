# Test per-element gas metering for array equality comparisons.
# Compares gas for small vs large arrays to verify cost scales with element count.

gno test -v .

stderr '--- PASS: ./small_array_filetest.gno \(elapsed: \d+\.\d\ds, gas: 5557\)'
stderr '--- PASS: ./large_array_filetest.gno \(elapsed: \d+\.\d\ds, gas: 325237\)'
stderr '--- PASS: ./nested_array_filetest.gno \(elapsed: \d+\.\d\ds, gas: 36631\)'

-- pkg.gno --
package gas_array_eql

-- small_array_filetest.gno --
// MAXALLOC: 500000000
package main

func main() {
	a1 := [1]int{}
	a2 := [1]int{}
	_ = a1 == a2
}

-- large_array_filetest.gno --
// MAXALLOC: 500000000
package main

func main() {
	a1 := [1000]int{}
	a2 := [1000]int{}
	_ = a1 == a2
}

-- nested_array_filetest.gno --
// MAXALLOC: 500000000
package main

func main() {
	a1 := [10][10]int{}
	a2 := [10][10]int{}
	_ = a1 == a2
}

-- gnomod.toml --
module = "gno.test/r/integ/gas_array_eql"
gno = "0.9"
