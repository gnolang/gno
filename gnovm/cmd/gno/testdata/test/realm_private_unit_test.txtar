# Test that a private realm's own unit tests (xxx_test package) can import the realm.
# See: https://github.com/gnolang/gno/issues/5053

# Set up GNOROOT in the current directory.
mkdir $WORK/gnovm/tests
symlink $WORK/gnovm/stdlibs -> $GNOROOT/gnovm/stdlibs
symlink $WORK/gnovm/tests/stdlibs -> $GNOROOT/gnovm/tests/stdlibs
env GNOROOT=$WORK

gno test -v ./privaterealm

stderr '=== RUN   TestHello'
stderr '--- PASS: TestHello.*'

-- gnowork.toml --
-- privaterealm/gnomod.toml --
module = "gno.test/r/integ/privaterealm"
gno = "0.9"
private = true

-- privaterealm/privaterealm.gno --
package privaterealm

func Hello() string { return "hello" }

-- privaterealm/privaterealm_test.gno --
package privaterealm_test

import (
	"testing"

	"gno.test/r/integ/privaterealm"
)

func TestHello(t *testing.T) {
	if privaterealm.Hello() != "hello" {
		t.Fatal("expected hello")
	}
}
