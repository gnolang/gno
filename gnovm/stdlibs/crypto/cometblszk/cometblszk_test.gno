package cometblszk_test

import (
	"crypto/cometblszk"
	"encoding/hex"
	"testing"
)

func mustHex(t *testing.T, s string) []byte {
	t.Helper()
	b, err := hex.DecodeString(s)
	if err != nil {
		t.Fatalf("invalid hex: %v", err)
	}
	return b
}

// Same vector as the Rust test_ok / the crypto/cometbls test.
func TestVerifyOK(t *testing.T) {
	chainID := "union-devnet-1337"
	trustedValidatorsHash := mustHex(t, "20DDFE7A0F75C65D876316091ECCD494A54A2BB324C872015F73E528D53CB9C4")

	header := cometblszk.LightHeader{
		Height:             3405691582,
		TimeSeconds:        1732205251,
		TimeNanos:          998131342,
		ValidatorsHash:     mustHex(t, "20DDFE7A0F75C65D876316091ECCD494A54A2BB324C872015F73E528D53CB9C4"),
		NextValidatorsHash: mustHex(t, "20DDFE7A0F75C65D876316091ECCD494A54A2BB324C872015F73E528D53CB9C4"),
		AppHash:            mustHex(t, "EE7E3E58F98AC95D63CE93B270981DF3EE54CA367F8D521ED1F444717595CD36"),
	}

	proof := mustHex(t,
		"03CF56142A1E03D2445A82100FEAF70C1CD95A731ED85792AFFF5792EC0BDD2108991BB56F9043A269F88903DE616A9AB99A3C5AB778E566744B060456C5616C"+
			"06BCE7F1930421768C2CBD79F88D08EC3A52D7C9A867064E973064385E9C945E02951190DD7CE1662546733DD540188C96E608CA750FEF36B39E2577833634C7"+
			"0AE6F1A6D00DC6C21446AAF285EF35D944E8782B131300574F9A889C7E708A2325E9A78013BBE869D38B19C602DAF69644C77D177E99ED76398BCEE13C61FDBF"+
			"2E178A5BA028A36033E54D1D9A0071E82E04079A5305347EBAC6D66F6EBFA48B1DA1BF9DC5A51EFA292E1DC7B85D26F18422EB386C48CA75434039764448BB96"+
			"268DDC2CF683DDCA4BD83DF21C5631CF784375EEBE77EABC2DE77886BF1D48392C9C52E063B4A7131EAB9ABBA12A9F26888BC37366D41AC7D4BAC0BF6755ACB0"+
			"09BF9F36F380B6D0EEAABF066503A1B6E01DCC965D968D7694E01B1755E6BDD21C7A80B41682748F9B7151714BE34AA79AAD48BBB2A84525F6CDF812658C6E4F",
	)

	if err := cometblszk.VerifyZKP(chainID, trustedValidatorsHash, header, proof); err != nil {
		t.Fatalf("VerifyZKP: %v", err)
	}
}

func TestVerifyTamperedBlock(t *testing.T) {
	chainID := "union-devnet-1337"
	trustedValidatorsHash := mustHex(t, "20DDFE7A0F75C65D876316091ECCD494A54A2BB324C872015F73E528D53CB9C4")

	header := cometblszk.LightHeader{
		Height:             3405691582,
		TimeSeconds:        1732205252, // tampered
		TimeNanos:          998131342,
		ValidatorsHash:     mustHex(t, "20DDFE7A0F75C65D876316091ECCD494A54A2BB324C872015F73E528D53CB9C4"),
		NextValidatorsHash: mustHex(t, "20DDFE7A0F75C65D876316091ECCD494A54A2BB324C872015F73E528D53CB9C4"),
		AppHash:            mustHex(t, "EE7E3E58F98AC95D63CE93B270981DF3EE54CA367F8D521ED1F444717595CD36"),
	}

	proof := mustHex(t,
		"03CF56142A1E03D2445A82100FEAF70C1CD95A731ED85792AFFF5792EC0BDD2108991BB56F9043A269F88903DE616A9AB99A3C5AB778E566744B060456C5616C"+
			"06BCE7F1930421768C2CBD79F88D08EC3A52D7C9A867064E973064385E9C945E02951190DD7CE1662546733DD540188C96E608CA750FEF36B39E2577833634C7"+
			"0AE6F1A6D00DC6C21446AAF285EF35D944E8782B131300574F9A889C7E708A2325E9A78013BBE869D38B19C602DAF69644C77D177E99ED76398BCEE13C61FDBF"+
			"2E178A5BA028A36033E54D1D9A0071E82E04079A5305347EBAC6D66F6EBFA48B1DA1BF9DC5A51EFA292E1DC7B85D26F18422EB386C48CA75434039764448BB96"+
			"268DDC2CF683DDCA4BD83DF21C5631CF784375EEBE77EABC2DE77886BF1D48392C9C52E063B4A7131EAB9ABBA12A9F26888BC37366D41AC7D4BAC0BF6755ACB0"+
			"09BF9F36F380B6D0EEAABF066503A1B6E01DCC965D968D7694E01B1755E6BDD21C7A80B41682748F9B7151714BE34AA79AAD48BBB2A84525F6CDF812658C6E4F",
	)

	if err := cometblszk.VerifyZKP(chainID, trustedValidatorsHash, header, proof); err == nil {
		t.Fatalf("expected tampered proof to fail verification")
	}
}
