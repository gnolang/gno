.dockerignore
Dockerfile
docker-compose.yml
build/
misc/*
!misc/loop/
!misc/autocounterd/
!misc/val-scenarios/
tests/docker-integration/
# docs/ is intentionally NOT excluded: gnoweb embeds the docs/ folder via
# the github.com/gnolang/gno/docs Go package, so the image needs the .md
# files and assets at build time. The whitepaper artifacts are large and
# unused at runtime, so we drop them individually below.
docs/gnoland-whitepaper.*
.github/
*.md
# Re-include docs/ Markdown after the `*.md` blanket exclusion above.
!docs/**/*.md
!docs/*.md

# Excluded to make Docker build cache stable across CI checkouts.
.git
.gitignore
.gitattributes

# Copied from .gitignore

# Editor Leftovers
.DS_Store
.vscode
.idea

# Default node data
gnoland-data
genesis.json

# Build leftovers
build

# Legacy .gitignore
data/*
testdir

# Log + generation leftovers
*.tx
*.log.*
*.log
*.gno.gen.go
*.gno.gen_test.go
*.pb.go
pbbindings.go
*~
.#*
*#

# Test coverage leftovers
cover.out
coverage.out
