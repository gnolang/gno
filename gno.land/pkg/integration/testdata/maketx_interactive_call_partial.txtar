# Interactive maketx: call with partial flags (missing -func, -gas-wanted, -gas-fee)
# When in interactive mode, missing required fields are prompted for.

loadpkg gno.land/r/demo/call_realm $WORK/realm

gnoland start

# Feed answers for prompts:
#   "Function name": GetName
#   "Gas estimation" choice: 2 (manual)
#   "Gas wanted": 2000000
#   "Gas fee": 1000000ugnot
#   "Proceed? [Y/n]": Y
input GetName
input 2
input 2000000
input 1000000ugnot
input Y
gnokey maketx call -pkgpath gno.land/r/demo/call_realm -broadcast -chainid=tendermint_test test1
stdout 'OK!'

-- realm/realm.gno --
package call_realm

var name string

func GetName(cur realm) string {
	return name
}

func SetName(cur realm, s string) string {
	name = s
	return name
}

func Render(_ string) string {
	return "# HELLO " + name
}
