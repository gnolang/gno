# Interactive maketx: --no-interactive flag prevents prompts
# When --no-interactive is set, missing required fields must produce
# errors just like the non-TTY behavior.

loadpkg gno.land/r/demo/call_realm $WORK/realm

gnoland start

# Missing -func with --no-interactive → error
! gnokey maketx call -pkgpath gno.land/r/demo/call_realm -gas-fee 1000000ugnot -gas-wanted 2000000 -broadcast -chainid=tendermint_test --no-interactive test1
stderr 'func not specified'

# Missing -gas-wanted with --no-interactive → error
! gnokey maketx call -pkgpath gno.land/r/demo/call_realm -func GetName -gas-fee 1000000ugnot -broadcast -chainid=tendermint_test --no-interactive test1
stderr 'gas-wanted not specified'

# All flags provided with --no-interactive → works normally
gnokey maketx call -pkgpath gno.land/r/demo/call_realm -func GetName -gas-fee 1000000ugnot -gas-wanted 2000000 -broadcast -chainid=tendermint_test --no-interactive test1
stdout 'OK!'

-- realm/realm.gno --
package call_realm

var name string

func GetName(cur realm) string {
	return name
}

func SetName(cur realm, s string) string {
	name = s
	return name
}

func Render(_ string) string {
	return "# HELLO " + name
}
