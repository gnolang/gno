# test panic

loadpkg gno.land/r/demo/panic $WORK

# start a new node
gnoland start


! gnokey maketx call -pkgpath gno.land/r/demo/panic --func Trigger --gas-fee 5000000ugnot --gas-wanted 50000000 --broadcast -chainid=tendermint_test test1

stderr 'p at gno.land/r/demo/panic/panic.gno:5'
stderr 'Trigger at gno.land/r/demo/panic/panic.gno:9'

-- panic.gno --
package main

func p() {
	i := "here"
	panic(i)
}

func Trigger(cur realm) {
	p()
}
