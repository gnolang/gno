# Estimating gas and gas fees for users
# using the 'gnokey maketx --simulate-only' option

# start a new node
gnoland start

# user's account sequence starts from 1 with 10000000000000ugnot
gnokey query auth/accounts/$test1_user_addr
stdout '"sequence": "0"'
stdout '"coins": "10000000000000ugnot"'

# Tx add package -simulate only, estimate gas used and gas fee.
# gas-wanted/gas-fee on the simulate call are generous; simulate reports
# a conservative (depth-based) estimate that is always >= the real tx cost.
gnokey maketx addpkg -pkgdir $WORK/hello -pkgpath gno.land/r/hello  -gas-wanted 6_000_000 -gas-fee 600001ugnot -chainid tendermint_test -simulate only test1
stdout 'GAS USED:\s+\d+'
stdout 'INFO:       estimated gas usage: \d+, gas fee: 5253ugnot, current gas price: 1ugnot/1000gas'

## No fee was charged, and the sequence number did not change.
gnokey query auth/accounts/$test1_user_addr
stdout '"sequence": "0"'
stdout '"coins": "10000000000000ugnot"'

# Using the simulated gas and estimated gas fee should ensure the transaction executes successfully.
# gas-wanted slightly above the simulation estimate; gas-fee covers that budget at 1ugnot/1000gas.
# Since simulation overestimates delivery gas, the actual tx always fits within the budget.
gnokey maketx addpkg -pkgdir $WORK/hello -pkgpath gno.land/r/hello  -gas-wanted 5_005_000 -gas-fee 5253ugnot -chainid tendermint_test test1
stdout 'OK'
stdout 'EVENTS:     \[.*"fee_delta":\{"denom":"ugnot","amount":206900\}.*\]'

## fee + storage deposit were charged; sequence number increased.
gnokey query auth/accounts/$test1_user_addr
stdout '"sequence": "1"'
stdout '"coins": "9999999787847ugnot"'

# Tx Call -simulate only, estimate gas used and gas fee.
gnokey maketx call -pkgpath gno.land/r/hello -func Hello -gas-wanted 3_000_000 -gas-fee 300001ugnot -chainid tendermint_test -simulate only test1
stdout 'GAS USED:\s+\d+'
stdout 'INFO:       estimated gas usage: \d+, gas fee: 2202ugnot, current gas price: 1ugnot/1000gas'

## No additional fee was charged, and the sequence number did not change.
gnokey query auth/accounts/$test1_user_addr
stdout '"sequence": "1"'
stdout '"coins": "9999999787847ugnot"'

# Using the simulated gas and estimated gas fee should ensure the transaction executes successfully.
gnokey maketx call -pkgpath gno.land/r/hello -func Hello -gas-wanted 2_100_000 -gas-fee 2202ugnot -chainid tendermint_test test1
stdout 'OK'

## fee is charged and sequence number increased
gnokey query auth/accounts/$test1_user_addr
stdout '"sequence": "2"'
stdout '"coins": "9999999785645ugnot"'

-- hello/gnomod.toml --
module = "gno.land/r/hello"
gno = "0.9"

-- hello/hello.gno --
package hello

var s = "hello"

func Hello(cur realm) string {
	return s
}
