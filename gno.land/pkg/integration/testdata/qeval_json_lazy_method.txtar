# Test vm/qeval_json on a lazy interface-bound method value (BoundMethodValue
# with Func == nil, resolved at call time). Regression: exportCopyValue used to
# nil-deref on the typed-nil Func and drop the Method selector.

loadpkg gno.land/r/test/lz $WORK/realm

gnoland start

# Height is racy (proof block), so match it with a regex and pin the data by
# distinctive substrings rather than a full golden.
gnokey query vm/qeval_json --data "gno.land/r/test/lz.GetG()"
stdout 'height: [1-9][0-9]*'
stdout '"@type":"/gno.BoundMethodValue"'
# The regression: Func stays typed-nil and the Method selector is not dropped.
stdout '"Func":null'
stdout '"Method":"Get","MethodPkg":"gno.land/r/test/lz"'
stdout '"@type":"/gno.RefType","ID":"gno.land/r/test/lz.Impl"'
stdout '"N":"AQAAAAAAAAA="'

-- realm/gnomod.toml --
module = "gno.land/r/test/lz"
gno = "0.9"

-- realm/realm.gno --
package lz

type IG interface{ Get() int }

type Impl struct{ x int }

func (i Impl) Get() int { return i.x }

func GetG() func() int {
	var o IG = Impl{x: 1}
	return o.Get
}
