# aaa namespace
loadpkg gno.land/r/aaa/bbb/ccc $WORK/ccc
loadpkg gno.land/r/aaa/ccc/ddd $WORK/ddd
loadpkg gno.land/r/aaa $WORK/aaa

# bbb namespace
loadpkg gno.land/r/bbb/ccc $WORK/ccc
loadpkg gno.land/p/bbb/ccc/ppp $WORK/ppp
loadpkg gno.land/r/bbb/aaa $WORK/aaa
loadpkg gno.land/r/bbb0 $WORK/bbb0

# foo-bar namespace (hyphenated; hyphens are allowed in intermediate path
# elements, only the last element must match the package name)
loadpkg gno.land/r/foo-bar/baz $WORK/baz
loadpkg gno.land/p/foo-bar/pkg $WORK/pkg

gnoland start

# query path for prefix
gnokey query vm/qpaths --data "gno.land/r/aaa"
stdout 'height: [1-9][0-9]*'
stdout 'data: gno.land/r/aaa'
stdout 'gno.land/r/aaa/bbb/ccc'
stdout 'gno.land/r/aaa/ccc/ddd'
! stderr '.+'

gnokey query vm/qpaths --data "gno.land/r/bbb"
stdout 'height: [1-9][0-9]*'
stdout 'data: gno.land/r/bbb/aaa'
stdout 'gno.land/r/bbb/ccc'
stdout 'gno.land/r/bbb0'
! stderr '.+'

gnokey query vm/qpaths --data "gno.land/r/bbb/"
stdout 'height: [1-9][0-9]*'
stdout 'data: gno.land/r/bbb/aaa'
stdout 'gno.land/r/bbb/ccc'
! stderr '.+'

# query path for namespace
gnokey query vm/qpaths --data "@bbb"
stdout 'height: [1-9][0-9]*'
stdout 'data: gno.land/p/bbb/ccc/ppp'
stdout 'gno.land/r/bbb/aaa'
stdout 'gno.land/r/bbb/ccc'
! stderr '.+'

# query path for namespace
gnokey query vm/qpaths --data "@bbb/ccc"
stdout 'height: [1-9][0-9]*'
stdout 'data: gno.land/p/bbb/ccc/ppp'
stdout 'gno.land/r/bbb/ccc'
! stderr '.+'

! gnokey query vm/qpaths --data "@invalid\\name"
cmp stdout invalid-name-qpaths.stdout.golden
cmp stderr invalid-name-qpaths.stderr.golden

gnokey query vm/qpaths --data "gno.land/r/ccc"
stdout 'height: [1-9][0-9]*'
stdout 'data: '
! stderr '.+'

gnokey query vm/qpaths?limit=5 --data "_"
stdout 'height: [1-9][0-9]*'
stdout 'data: bufio'
stdout 'bytes'
stdout 'chain'
stdout 'chain/banker'
stdout 'chain/markdown'
! stderr '.+'

gnokey query vm/qpaths --data "_/encoding"
stdout 'height: [1-9][0-9]*'
stdout 'data: encoding'
stdout 'encoding/base32'
stdout 'encoding/base64'
stdout 'encoding/binary'
stdout 'encoding/csv'
stdout 'encoding/hex'
! stderr '.+'

gnokey query vm/qpaths?limit=5 --data ""
stdout 'height: [1-9][0-9]*'
stdout 'data: bufio'
stdout 'bytes'
stdout 'chain'
stdout 'chain/banker'
stdout 'chain/markdown'
! stderr '.+'

# query path for namespace with hyphen
gnokey query vm/qpaths --data "@foo-bar"
stdout 'height: [1-9][0-9]*'
stdout 'data: gno.land/p/foo-bar/pkg'
stdout 'gno.land/r/foo-bar/baz'
! stderr '.+'

gnokey query vm/qpaths --data "@foo-bar/baz"
stdout 'height: [1-9][0-9]*'
stdout 'data: gno.land/r/foo-bar/baz'
! stderr '.+'

-- aaa/aaa.gno --
package aaa

func Hello() { println("AAA") }

-- ccc/ccc.gno --
package ccc

func Hello() { println("CCC") }

-- ddd/ddd.gno --
package ddd

func Hello() { println("DDD") }

-- ppp/ppp.gno --
package ppp

func Hello() { println("PPP") }

-- bbb0/bbb0.gno --
package bbb0

func Hello() { println("BBB0") }

-- baz/baz.gno --
package baz

func Hello() { println("BAZ") }

-- pkg/pkg.gno --
package pkg

func Hello() { println("PKG") }

-- invalid-name-qpaths.stdout.golden --
Log: --= Error =--
Data: errors.FmtError{format:"invalid username format", args:[]interface {}(nil)}
Msg Traces:
--= /Error =--

-- invalid-name-qpaths.stderr.golden --
"gnokey" error: invalid username format
