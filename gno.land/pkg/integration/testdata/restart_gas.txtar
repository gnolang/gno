# Pin exact gas for three equivalent-shape AddPkg txs straddling a node
# restart. Any VM, store, or gas-model change that shifts these numbers
# MUST update them here — this is the regression signal that the test's
# name ("restart_gas") implies.
#
# `foo` (pre-restart, same shape as bar but different pkgpath/name) and
# `baz` (post-restart, same shape) should stay close; a large divergence
# between them indicates restart-dependent gas, which is a bug.

gnoland start

gnokey maketx addpkg -pkgdir $WORK/bar -pkgpath gno.land/r/$test1_user_addr/bar -gas-fee 1000000ugnot -gas-wanted 100000000 -chainid=tendermint_test test1
stdout 'GAS USED: +2839212'

gnokey maketx addpkg -pkgdir $WORK/foo -pkgpath gno.land/r/$test1_user_addr/foo -gas-fee 1000000ugnot -gas-wanted 100000000 -chainid=tendermint_test test1
stdout 'GAS USED: +2841531'

gnoland restart

gnokey maketx addpkg -pkgdir $WORK/baz -pkgpath gno.land/r/$test1_user_addr/baz -gas-fee 1000000ugnot -gas-wanted 100000000 -chainid=tendermint_test test1
stdout 'GAS USED: +2841558'

-- bar/gnomod.toml --
module = "bar"
gno = "0.9"

-- bar/hello.gno --
package bar

import "chain/runtime/unsafe"

func PreviousRealm(cur realm) string {
	return unsafe.PreviousRealm().String()
}

-- baz/gnomod.toml --
module = "baz"
gno = "0.9"

-- baz/hello.gno --
package baz

import "chain/runtime/unsafe"

func PreviousRealm(cur realm) string {
	return unsafe.PreviousRealm().String()
}

-- foo/gnomod.toml --
module = "foo"
gno = "0.9"

-- foo/hello.gno --
package foo

import "chain/runtime/unsafe"

func PreviousRealm(cur realm) string {
	return unsafe.PreviousRealm().String()
}
