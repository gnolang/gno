	"gno.land/p/test/v2lib"
	"gno.land/r/test/owned"
)

var Lib = &v2lib.LibContainer{A: 0}

func MutateOwnedVia(r *owned.Resource) {
	r.Mutate()
}

func Render(_ string) string {
	return ufmt.Sprintf("neighborLibA=%d", Lib.A)
}


-- caller/gnomod.toml --
module = "gno.land/r/test/caller"
gno = "0.9"

-- caller/caller.gno --
package caller

import (
	"gno.land/p/test/v2lib"
	"gno.land/r/test/neighbor"
	"gno.land/r/test/owned"
)

// ----- Layer 1 -----

func L1_FnTopLevel(cur realm) {
	owned.MutateGlobal(5)
}

func L1_MethodRealSelf(cur realm) {
	owned.Real.Mutate()
}

func L1_MethodRealForeignWrite(cur realm) {
	owned.OverwriteA(neighbor.Lib)
}

func L1_MethodUnrealSelf(cur realm) {
	r := owned.Factory()
	r.Mutate()
}

func L1_Closure(cur realm) {
	owned.Closure()
}

func L1_BoundMethod(cur realm) {
	f := owned.Real.Mutate
	f()
}

func L1_ValueReceiver(cur realm) {
	owned.RecordValueReceiverTrace()
}

func L1_MultiHop(cur realm) {
	neighbor.MutateOwnedVia(owned.Real)
}

func L1_CrossingExplicit(cur realm) {
	owned.PublicSet(cross, 99)
}

// ----- Layer 2 -----

func L2_PMethodOnOwnedReal(cur realm) {
	owned.Lib.TouchA()
}

func L2_PMethodOnOwnedUnreal(cur realm) {
	lc := owned.LibFactory()
	lc.TouchA()
}

func L2_PMethodOnNeighborReceiver(cur realm) {
	neighbor.Lib.TouchA()
}

func L2_PMethodOnPrimitiveReceiver(cur realm) {
	var p v2lib.PrimitiveCounter = 42
	_ = p.Touch()
}

// ----- Interface dispatch -----

func IFACE_DispatchTargetsDeclaring(cur realm) {
	var t v2lib.Toucher = owned.NewEvilToucher()
	t.Touch()
}

// ----- Construction-time -----

func CONSTRUCT_CompositeLitFails(cur realm) {
	_ = &owned.Resource{Value: 1}
}

func CONSTRUCT_NewFails(cur realm) {
	_ = new(owned.Resource)
}

// ----- Readonly taint -----

func READONLY_RoundTripFails(cur realm) {
	owned.MutateSlice(owned.GlobalSlice)
}

// ----- Realm-context invariant -----

func CTX_BorrowDoesNotShiftCurrentRealm(cur realm) {
	owned.Real.RecordRealmTraceForCTX()
}

// ----- Defer/recover -----

func DEFER_BorrowUnwindAfterRecover(cur realm) {
	defer func() {
		if recover() != nil {
			owned.RecordDeferResume()
		}
	}()
	owned.PanicInsideBorrow()
}

// ----- Copy semantics -----

func COPY_PreservesPkgID(cur realm) {
	r := owned.Factory()
	// value-method dispatch — Copy preserves PkgID:
	id := (*r).Identify()
	owned.RecordCopyTrace(id)
}

func COPY_PInitRestampedToCurRealm(cur realm) {
	n := v2lib.CopyAndMutate(42)
	if n != 42 {
		panic("write did not take effect")
	}
	owned.RecordCopyTrace("PInitRestamped")
}


