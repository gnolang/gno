# interrealm v2 borrow rule — exhaustive behavior reference.
#
# Affirmative-coverage counterpart to the pre-interrealm-v2 tests
# interrealm_final.txtar / interrealm_mix_call.txtar /
# interrealm_mix_run.txtar (which test the inverted pre-Layer-1-borrow
# semantics). Kept side-by-side so a reader can compare expectations.
#
# Each case is a small function on /r/test/caller invoked via
# `gnokey maketx call`. Cases that need to observe runtime state
# write to /r/test/owned's package vars and the assertion reads
# them via `vm/qrender` (since `println` side-effects are not
# captured by maketx call's stdout).
#
# interrealm v2 rules under test (see gnovm/adr/interrealm_v2.md § "Storage = Authority" and
# docs/resources/gno-interrealm.md § "Implicit Realm-Storage Borrowing"):
#
#   Layer 1 — declaring-realm borrow:  any /r/X-declared callable
#     (function, method on any receiver shape, closure, interface
#     dispatch to /r/X-declared method) runs its body with
#     m.Realm = /r/X for the call duration.
#
#   Layer 2 — storage-realm borrow:  a /p/-declared (or stdlib)
#     method invoked on a defined receiver whose authoring PkgID
#     differs from m.Realm soft-switches m.Realm to the receiver's
#     PkgID. Under interrealm v2 Phase 3 this fires for both REAL and UNREAL
#     foreign receivers.
#
#   Realm-context invariant:  Borrow shifts m.Realm but NOT
#     runtime.CurrentRealm()/PreviousRealm(); those track only
#     explicit fn(cross, ...) crossings.
#
#   Construction-time:  composite literals, new(), make() of foreign
#     /r/-declared types panic at the call site.
#
#   Readonly taint:  values read from foreign-realm state carry
#     N_Readonly; later writes panic, surviving conversions (Phase 4).
#
#   Copy semantics:  Copy preserves source PkgID when the source
#     carries realm authority (Phase 2d); when the source PkgID is
#     non-realm (stdlib or /p/ init), the copy is restamped to the
#     copying realm so a /r/-caller can mutate its own local copy of
#     a /p/-init default value.
#
# Narrow filetests for behaviors that don't need integration:
#   - gnovm/tests/files/zrealm_v2_construction_composite_fail.gno
#   - gnovm/tests/files/zrealm_v2_construction_new_fail.gno
#   - gnovm/tests/files/zrealm_v2_foreign_mutate_unreal_bytes.gno
#   - gnovm/tests/files/zrealm_p_convert_readonly_ok_filetest.gno
#   - gnovm/tests/files/exploit/realm_exploiter.gno

loadpkg gno.land/p/nt/ufmt/v0

gnoland start

## ============================================================
## Setup
## ============================================================

gnokey maketx addpkg -pkgdir $WORK/lib -pkgpath gno.land/p/test/v2lib -gas-fee 360001ugnot -gas-wanted 3_600_000 -chainid=tendermint_test test1
stdout OK!

gnokey maketx addpkg -pkgdir $WORK/owned -pkgpath gno.land/r/test/owned -gas-fee 1000001ugnot -gas-wanted 10_000_000 -chainid=tendermint_test test1
stdout OK!

gnokey maketx addpkg -pkgdir $WORK/neighbor -pkgpath gno.land/r/test/neighbor -gas-fee 700001ugnot -gas-wanted 7_000_000 -chainid=tendermint_test test1
stdout OK!

gnokey maketx addpkg -pkgdir $WORK/caller -pkgpath gno.land/r/test/caller -gas-fee 1000001ugnot -gas-wanted 10_000_000 -chainid=tendermint_test test1
stdout OK!

gnokey query "vm/qrender" --data "gno.land/r/test/owned:"
stdout 'global=0 realValue=0 libA=0 slice0=1 trace='

gnokey query "vm/qrender" --data "gno.land/r/test/neighbor:"
stdout 'neighborLibA=0'


## ============================================================
## Layer 1 — declaring-realm borrow
## ============================================================

## L1_FnTopLevel: top-level /r/-declared fn invoked from foreign realm.
## Body's `global = n` succeeds (Layer 1 borrow → m.Realm = /r/owned).
##
##   func L1_FnTopLevel(cur realm) {
##       owned.MutateGlobal(5)
##   }
gnokey maketx call -pkgpath gno.land/r/test/caller -func L1_FnTopLevel -gas-fee 800001ugnot -gas-wanted 8_000_000 -chainid=tendermint_test test1
stdout OK!
gnokey query "vm/qrender" --data "gno.land/r/test/owned:"
stdout 'global=5 '

## L1_MethodRealSelf: method on real receiver writes to own field.
##
##   func L1_MethodRealSelf(cur realm) {
##       owned.Real.Mutate()
##   }
gnokey maketx call -pkgpath gno.land/r/test/caller -func L1_MethodRealSelf -gas-fee 800001ugnot -gas-wanted 8_000_000 -chainid=tendermint_test test1
stdout OK!
gnokey query "vm/qrender" --data "gno.land/r/test/owned:"
stdout 'realValue=1 '

## L1_MethodRealForeignWrite: /r/owned method writes to a
## /r/neighbor-owned field. Layer 1 borrow shifts m.Realm to
## /r/owned, the foreign-field write panics on readonly taint.
##
##   func L1_MethodRealForeignWrite(cur realm) {
##       owned.OverwriteA(neighbor.Lib)
##   }
! gnokey maketx call -pkgpath gno.land/r/test/caller -func L1_MethodRealForeignWrite -gas-fee 1000000ugnot -gas-wanted 10000000 -chainid=tendermint_test test1
stderr 'cannot directly modify readonly tainted object'

## L1_MethodUnrealSelf: method on UNREAL receiver succeeds in memory
## but produces no persisted state delta (receiver discarded).
##
##   func L1_MethodUnrealSelf(cur realm) {
##       r := owned.Factory()
##       r.Mutate()
##   }
gnokey maketx call -pkgpath gno.land/r/test/caller -func L1_MethodUnrealSelf -gas-fee 800001ugnot -gas-wanted 8_000_000 -chainid=tendermint_test test1
stdout OK!
gnokey query "vm/qrender" --data "gno.land/r/test/owned:"
stdout 'realValue=1 '

## L1_Closure: closure captured at /r/owned package-level. Borrow
## fires on the closure's construction-site realm.
##
##   func L1_Closure(cur realm) {
##       owned.Closure()
##   }
gnokey maketx call -pkgpath gno.land/r/test/caller -func L1_Closure -gas-fee 800001ugnot -gas-wanted 8_000_000 -chainid=tendermint_test test1
stdout OK!
gnokey query "vm/qrender" --data "gno.land/r/test/owned:"
stdout 'global=6 '

## L1_BoundMethod: bound-method dispatch (`f := obj.M; f()`) goes
## through BoundMethodValue, still triggers Layer 1.
##
##   func L1_BoundMethod(cur realm) {
##       f := owned.Real.Mutate
##       f()
##   }
gnokey maketx call -pkgpath gno.land/r/test/caller -func L1_BoundMethod -gas-fee 800001ugnot -gas-wanted 8_000_000 -chainid=tendermint_test test1
stdout OK!
gnokey query "vm/qrender" --data "gno.land/r/test/owned:"
stdout 'realValue=2 '

## L1_ValueReceiver: value-method dispatch creates a copy via
## VPValMethod → StructValue.Copy (interrealm v2 Phase 2d preserves source
## PkgID). Borrow targets the declaring realm of the method, not
## caller. The body writes its observation to owned.trace, asserted
## via qrender below.
##
##   func L1_ValueReceiver(cur realm) {
##       owned.RecordValueReceiverTrace()
##   }
gnokey maketx call -pkgpath gno.land/r/test/caller -func L1_ValueReceiver -gas-fee 800001ugnot -gas-wanted 8_000_000 -chainid=tendermint_test test1
stdout OK!
gnokey query "vm/qrender" --data "gno.land/r/test/owned:"
stdout 'trace=L1_ValueReceiver:cur=gno.land/r/test/caller'

## L1_MultiHop: caller → neighbor.MutateOwnedVia → owned.Real.Mutate.
## Two Layer 1 borrows on the stack; both unwind correctly.
##
##   func L1_MultiHop(cur realm) {
##       neighbor.MutateOwnedVia(owned.Real)
##   }
gnokey maketx call -pkgpath gno.land/r/test/caller -func L1_MultiHop -gas-fee 800001ugnot -gas-wanted 8_000_000 -chainid=tendermint_test test1
stdout OK!
gnokey query "vm/qrender" --data "gno.land/r/test/owned:"
stdout 'realValue=3 '

## L1_CrossingExplicit: explicit fn(cross, ...) shifts BOTH realm-
## context AND storage-context to /r/owned. Body's CurrentRealm
## reports /r/owned, PreviousRealm reports /r/caller.
##
##   func L1_CrossingExplicit(cur realm) {
##       owned.PublicSet(cross, 99)
##   }
gnokey maketx call -pkgpath gno.land/r/test/caller -func L1_CrossingExplicit -gas-fee 800001ugnot -gas-wanted 8_000_000 -chainid=tendermint_test test1
stdout OK!
gnokey query "vm/qrender" --data "gno.land/r/test/owned:"
stdout 'global=99 '
stdout 'trace=L1_CrossingExplicit:cur=gno.land/r/test/owned,prev=gno.land/r/test/caller'

## L1_NonCrossingOfCrossing: a non-cross call of a crossing fn from
## a foreign realm is rejected at PREPROCESS time. Demonstrated as
## a fail-to-deploy package below.
! gnokey maketx addpkg -pkgdir $WORK/fail_nocross -pkgpath gno.land/r/test/fail_nocross -gas-fee 1000000ugnot -gas-wanted 10000000 -chainid=tendermint_test test1
stderr 'cannot cur-call to external realm function'


## ============================================================
## Layer 2 — storage-realm borrow on /p/-method
## ============================================================

## L2_PMethodOnOwnedReal: /p/-method on real /r/owned-allocated
## receiver. Layer 2 borrows m.Realm to /r/owned; write succeeds.
##
##   func L2_PMethodOnOwnedReal(cur realm) {
##       owned.Lib.TouchA()
##   }
gnokey maketx call -pkgpath gno.land/r/test/caller -func L2_PMethodOnOwnedReal -gas-fee 800001ugnot -gas-wanted 8_000_000 -chainid=tendermint_test test1
stdout OK!
gnokey query "vm/qrender" --data "gno.land/r/test/owned:"
stdout 'libA=1 '

## L2_PMethodOnOwnedUnreal: interrealm v2 Phase 3 expansion — Layer 2 fires
## for unreal foreign receivers too. owned.LibFactory() returns
## a PkgID=/r/owned LibContainer with NewTime=0; TouchA still
## borrows to /r/owned.
##
##   func L2_PMethodOnOwnedUnreal(cur realm) {
##       lc := owned.LibFactory()
##       lc.TouchA()
##   }
gnokey maketx call -pkgpath gno.land/r/test/caller -func L2_PMethodOnOwnedUnreal -gas-fee 800001ugnot -gas-wanted 8_000_000 -chainid=tendermint_test test1
stdout OK!
# unreal receiver — no persisted state delta

## L2_PMethodOnNeighborReceiver: 3-realm geometry. Receiver in
## /r/neighbor. Layer 2 → /r/neighbor (not /r/owned, not /r/caller).
##
##   func L2_PMethodOnNeighborReceiver(cur realm) {
##       neighbor.Lib.TouchA()
##   }
gnokey maketx call -pkgpath gno.land/r/test/caller -func L2_PMethodOnNeighborReceiver -gas-fee 800001ugnot -gas-wanted 8_000_000 -chainid=tendermint_test test1
stdout OK!
gnokey query "vm/qrender" --data "gno.land/r/test/neighbor:"
stdout 'neighborLibA=1'

## L2_PMethodOnPrimitiveReceiver: primitive-receiver /p/-method does
## NOT trigger Layer 2 (no Object identity to carry PkgID).
##
##   func L2_PMethodOnPrimitiveReceiver(cur realm) {
##       var p v2lib.PrimitiveCounter = 42
##       _ = p.Touch()
##   }
gnokey maketx call -pkgpath gno.land/r/test/caller -func L2_PMethodOnPrimitiveReceiver -gas-fee 800001ugnot -gas-wanted 8_000_000 -chainid=tendermint_test test1
stdout OK!


