module = "gno.land/r/test/fail_nocross"
gno = "0.9"

-- fail_nocross/main.gno --
// INTENTIONALLY broken — addpkg must fail at preprocess with
// "cannot cur-call to external realm function ...". Demonstrates
// that the non-crossing-of-crossing-fn pattern is rejected at
// compile time, not just at runtime.
package fail_nocross

import "gno.land/r/test/owned"

func Trigger(cur realm) {
	owned.PublicSet(cur, 99)
}
