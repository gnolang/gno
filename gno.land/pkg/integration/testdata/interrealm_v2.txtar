## ============================================================
## Readonly taint
## ============================================================

## READONLY_RoundTripFails: caller reads owned.GlobalSlice (carries
## N_Readonly from the dot-selector read), passes back through
## owned.MutateSlice. Even with Layer 1 borrow active, the taint
## survives and the indexed write panics.
##
##   func READONLY_RoundTripFails(cur realm) {
##       owned.MutateSlice(owned.GlobalSlice)
##   }
! gnokey maketx call -pkgpath gno.land/r/test/caller -func READONLY_RoundTripFails -gas-fee 1000000ugnot -gas-wanted 10000000 -chainid=tendermint_test test1
stderr 'cannot directly modify readonly tainted object'


## ============================================================
## Realm-context invariant
## ============================================================

## CTX_BorrowDoesNotShiftCurrentRealm: Layer 1 borrow shifts m.Realm
## but NOT runtime.CurrentRealm(). Inside the borrowed body,
## CurrentRealm reports caller (or user for top-level user calls).
##
##   func CTX_BorrowDoesNotShiftCurrentRealm(cur realm) {
##       owned.Real.RecordRealmTraceForCTX()
##   }
gnokey maketx call -pkgpath gno.land/r/test/caller -func CTX_BorrowDoesNotShiftCurrentRealm -gas-fee 800001ugnot -gas-wanted 8_000_000 -chainid=tendermint_test test1
stdout OK!
gnokey query "vm/qrender" --data "gno.land/r/test/owned:"
stdout 'trace=CTX:cur=gno.land/r/test/caller'


## ============================================================
## Defer/recover
## ============================================================

## DEFER_BorrowUnwindAfterRecover: a borrowed-realm method panics.
## In Gno, cross-realm panics are NOT caught by ordinary recover()
## from a foreign realm — the runtime escalates them past defer/
## recover boundaries to enforce realm-boundary safety. The
## equivalent capability is `revive(fn)` (see panic-revive spec).
## This case demonstrates that an unrecovered cross-realm panic
## leaks through caller's defer/recover and aborts the tx.
##
##   func DEFER_BorrowUnwindAfterRecover(cur realm) {
##       defer func() {
##           if recover() != nil {
##               owned.RecordDeferResume()
##           }
##       }()
##       owned.PanicInsideBorrow()
##   }
! gnokey maketx call -pkgpath gno.land/r/test/caller -func DEFER_BorrowUnwindAfterRecover -gas-fee 800001ugnot -gas-wanted 8_000_000 -chainid=tendermint_test test1
stderr 'intentional panic for unwind test'


## ============================================================
## Copy semantics
## ============================================================

## COPY_PreservesPkgID: value-method dispatch copies the receiver
## via StructValue.Copy; interrealm v2 Phase 2d preserves source PkgID.
## (Same mechanism as L1_ValueReceiver, but the trace records the
## copy's effective declaring realm rather than just the borrow
## target.)
##
##   func COPY_PreservesPkgID(cur realm) {
##       r := owned.Factory()
##       // value-method dispatch — Copy preserves PkgID:
##       id := (*r).Identify()
##       owned.RecordCopyTrace(id)
##   }
gnokey maketx call -pkgpath gno.land/r/test/caller -func COPY_PreservesPkgID -gas-fee 800001ugnot -gas-wanted 8_000_000 -chainid=tendermint_test test1
stdout OK!
gnokey query "vm/qrender" --data "gno.land/r/test/owned:"
stdout 'trace=COPY:gno.land/r/test/owned'

## COPY_PInitRestampedToCurRealm: a /p/ helper (CopyAndMutate) copies
## its /p/-init-allocated default into a local and writes through that
## local — the same pattern as gno.land/p/jeronimoalbi/datasource.NewQuery.
## Without the IsRealmPkg gate in Copy the local would inherit /p/'s
## PkgID and the write would trip the readonly check (m.Realm = caller
## ≠ /p/); with the gate, the copy is restamped to currentRealmID and
## the mutation succeeds.
##
##   func COPY_PInitRestampedToCurRealm(cur realm) {
##       n := v2lib.CopyAndMutate(42)
##       if n != 42 {
##           panic("write did not take effect")
##       }
##       owned.RecordCopyTrace("PInitRestamped")
##   }
gnokey maketx call -pkgpath gno.land/r/test/caller -func COPY_PInitRestampedToCurRealm -gas-fee 800001ugnot -gas-wanted 8_000_000 -chainid=tendermint_test test1
stdout OK!
gnokey query "vm/qrender" --data "gno.land/r/test/owned:"
stdout 'trace=COPY:PInitRestamped'


## ============================================================
## Fixture realms
## ============================================================

-- lib/gnomod.toml --
module = "gno.land/p/test/v2lib"
gno = "0.9"

-- lib/lib.gno --
package v2lib

type LibContainer struct {
	A int
}

func (lc *LibContainer) TouchA() {
	lc.A++
}

// DefaultLib is allocated at /p/ init time; its StructValue carries
// PkgID = /p/test/v2lib (non-realm). CopyAndMutate exercises the same
// pattern as gno.land/p/jeronimoalbi/datasource.NewQuery: a /p/ helper
// copies the default and mutates the local. Without the IsRealmPkg
// gate in Copy, the local would carry /p/ PkgID and the write would
// trip the readonly check (m.Realm = caller's realm ≠ /p/).
var DefaultLib = LibContainer{A: 7}

func CopyAndMutate(newA int) int {
	c := DefaultLib
	c.A = newA
	return c.A
}

type PrimitiveCounter int

func (pc PrimitiveCounter) Touch() PrimitiveCounter {
	return pc + 1
}

type Toucher interface {
	Touch()
}


-- owned/gnomod.toml --
module = "gno.land/r/test/owned"
gno = "0.9"

-- owned/owned.gno --
package owned

import (
	"chain/runtime"
	"gno.land/p/nt/ufmt/v0"
	"gno.land/p/test/v2lib"
)

type Resource struct {
	Value int
}

func (r *Resource) Mutate() {
	r.Value++
}

func (r Resource) Identify() string {
	return "gno.land/r/test/owned"
}

func (r *Resource) RecordRealmTraceForCTX() {
	trace = "CTX:cur=" + runtime.CurrentRealm().PkgPath()
}

var (
	global      int
	Real        = &Resource{Value: 0}
	Lib         = &v2lib.LibContainer{A: 0}
	GlobalSlice = []int{1, 2, 3}
	trace       string
)

func MutateGlobal(n int) {
	global = n
}

func OverwriteA(lc *v2lib.LibContainer) {
	lc.A = 99
}

func Factory() *Resource {
	return &Resource{Value: 0}
}

func LibFactory() *v2lib.LibContainer {
	return &v2lib.LibContainer{A: 0}
}

var Closure = func() {
	global++
}

func PublicSet(cur realm, n int) {
	global = n
	trace = "L1_CrossingExplicit:cur=" + runtime.CurrentRealm().PkgPath() +
		",prev=" + runtime.PreviousRealm().PkgPath()
}

// RecordValueReceiverTrace is invoked from L1_ValueReceiver. It runs
// under Layer 1 borrow to /r/owned; from inside, CurrentRealm reports
// the caller (the realm-context which borrow does NOT shift).
func RecordValueReceiverTrace() {
	trace = "L1_ValueReceiver:cur=" + runtime.CurrentRealm().PkgPath()
}

// MutateSlice — readonly round-trip target.
func MutateSlice(s []int) {
	s[0] = 0xff
}

type EvilToucher struct{}

func (e *EvilToucher) Touch() {
	global++
}

// NewEvilToucher returns an unreal EvilToucher; used by
// IFACE_DispatchTargetsDeclaring to put an /r/owned-declared type
// behind a /p/-declared interface in caller's scope. PkgID=/r/owned.
func NewEvilToucher() *EvilToucher {
	return &EvilToucher{}
}

// PanicInsideBorrow is invoked by DEFER_BorrowUnwindAfterRecover.
// Panics inside the Layer 1 borrowed body; caller recovers.
func PanicInsideBorrow() {
	panic("intentional panic for unwind test")
}

// RecordDeferResume is called AFTER caller's recover. If m.Realm was
// not restored, the write to `trace` (a /r/owned package var) would
// fail. So the success of this call is the unwind correctness signal.
func RecordDeferResume() {
	trace = "DEFER:recovered-and-resumed"
}

// RecordCopyTrace — body of COPY_PreservesPkgID. Called from caller
// through value-method dispatch (Identify equivalent); the body
// records its observed declaring realm.
func RecordCopyTrace(observed string) {
	trace = "COPY:" + observed
}

func Render(_ string) string {
	return ufmt.Sprintf(
		"global=%d realValue=%d libA=%d slice0=%d trace=%s",
		global, Real.Value, Lib.A, GlobalSlice[0], trace)
}


-- neighbor/gnomod.toml --
