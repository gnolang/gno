## Cross-tx load path for multiple zero-sized types. Each pointer
## persisted at genesis is a RefValue with the reserved zerobase
## ObjectID; on reload, the values.go PointerValue branch must
## recover the element type from the outer PointerType and route to
## the correct per-TypeID sentinel via Store.Zerobase(elt). If the
## load path crossed wires between types, one or more comparisons
## below would return false.

loadpkg gno.land/r/zerobase_multi $WORK

gnoland start

gnokey maketx call -pkgpath gno.land/r/zerobase_multi -func CheckLoaded -gas-fee 5000000ugnot -gas-wanted 2000000 -chainid=tendermint_test test1
stdout 'foo=true bar=true zArr=true nestedZS=true'

-- gnomod.toml --
module = "gno.land/r/zerobase_multi"
gno = "0.9"

-- multi.gno --
package zerobase_multi

import "strconv"

type Foo struct{}
type Bar struct{}
type NestedZS struct {
	_ [0]int
}

// Each global below is a *T where T is a distinct zero-sized type.
// At genesis the pointers persist as RefValue{ObjectID: zerobaseOID}
// in this realm's block; CheckLoaded runs in a later tx, forcing
// the load path to materialize the in-memory sentinel for each type.
var (
	pFoo      = new(Foo)
	pBar      = new(Bar)
	pZArr     = new([0]int)
	pNestedZS = new(NestedZS)
)

func CheckLoaded(_ realm) string {
	qFoo := new(Foo)
	qBar := new(Bar)
	qZArr := new([0]int)
	qNestedZS := new(NestedZS)

	return "foo=" + strconv.FormatBool(pFoo == qFoo) +
		" bar=" + strconv.FormatBool(pBar == qBar) +
		" zArr=" + strconv.FormatBool(pZArr == qZArr) +
		" nestedZS=" + strconv.FormatBool(pNestedZS == qNestedZS)
}
