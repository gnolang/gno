# Test that calling PayGas from main() via MsgRun panics.
# main is not a realm — PayGas must be called from a realm.

## start a new node
gnoland start

## run a script that calls PayGas directly from main
! gnokey maketx run -gas-fee 1000000ugnot -gas-wanted 2000000 -broadcast -chainid=tendermint_test test1 $WORK/main.gno
stderr 'caller is not a realm'

-- main.gno --
package main

import "chain/runtime"

func main() {
	runtime.PayGas(1000000) // main calling PayGas — should panic
}
