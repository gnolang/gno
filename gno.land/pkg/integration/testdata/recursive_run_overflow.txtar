# Regression test: many panicking defers must not crash the node.
#
# Before the fix, Machine.Run() recursively called itself for each Go-level
# *Exception panic from a deferred function. With enough panicking defers,
# this exceeded the Go runtime's goroutine stack limit, killing the node
# with a fatal runtime.throw that bypasses all recover() handlers.

gnoland start

# Deploy realm that panics in init via many deferred nil derefs — must fail
# with a panic error, NOT crash the node.
! gnokey maketx addpkg -pkgdir $WORK/r1 -pkgpath gno.land/r/test/panicdefer -gas-fee 10000000ugnot -gas-wanted 100_000_000 -simulate skip -broadcast -chainid=tendermint_test test1
! stdout OK!
stderr 'nil pointer dereference'

# Verify the node is still alive by deploying a simple realm after.
gnokey maketx addpkg -pkgdir $WORK/r2 -pkgpath gno.land/r/test/alive -gas-fee 10000000ugnot -gas-wanted 10_000_000 -simulate skip -broadcast -chainid=tendermint_test test1
stdout OK!

gnokey query vm/qeval --data 'gno.land/r/test/alive.Hello()'
stdout 'still alive'

-- r1/gnomod.toml --
module = "gno.land/r/test/panicdefer"
gno = "0.9"

-- r1/realm.gno --
package panicdefer

type S struct{ X int }

func init() {
	for i := 0; i < 1000; i++ {
		defer func() {
			var p *S
			_ = p.X
		}()
	}
	var p *S
	_ = p.X
}

-- r2/gnomod.toml --
module = "gno.land/r/test/alive"
gno = "0.9"

-- r2/realm.gno --
package alive

func Hello() string {
	return "still alive"
}
