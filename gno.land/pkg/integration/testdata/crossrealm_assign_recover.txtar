# Test that cross-realm assign+recover does NOT corrupt state.
#
# The readonly check in PopAsPointer fires BEFORE the mutation,
# so recover() catches the panic but no state change occurs.
#
#  1. Deploy a victim realm with admin=deployer and vote tally (10:90 → rejected).
#  2. TX1 (MsgRun): attacker attempts assign+recover — state unchanged.
#  3. TX2 (MsgCall): verify state is still original (no corruption).

## Setup users
adduser deployer
adduser attacker

## start a new node
gnoland start

## Deploy the victim realm
gnokey maketx addpkg -pkgdir $WORK/victim -pkgpath gno.land/r/test/victim -gas-fee 1000000ugnot -gas-wanted 100000000 -broadcast -chainid=tendermint_test deployer
stdout 'OK!'

## Verify initial state
gnokey maketx call -pkgpath gno.land/r/test/victim -func GetAdmin -gas-fee 1000000ugnot -gas-wanted 10000000 -broadcast -chainid=tendermint_test deployer
stdout ${deployer_user_addr}

gnokey maketx call -pkgpath gno.land/r/test/victim -func GetResult -gas-fee 1000000ugnot -gas-wanted 10000000 -broadcast -chainid=tendermint_test deployer
stdout 'rejected'

## ============================================
## TX1: Attempt assign+recover — no corruption
## ============================================
gnokey maketx run -gas-fee 1000000ugnot -gas-wanted 100000000 -broadcast -chainid=tendermint_test attacker $WORK/exploit/exploit.gno
stdout 'admin corrupted in-tx: false'
stdout 'vote corrupted in-tx: false'
stdout 'corruption done'

## ============================================
## TX2: Verify state is still original
## ============================================

## Admin must still be the deployer
gnokey maketx call -pkgpath gno.land/r/test/victim -func GetAdmin -gas-fee 1000000ugnot -gas-wanted 10000000 -broadcast -chainid=tendermint_test deployer
stdout ${deployer_user_addr}

## Vote must still be rejected
gnokey maketx call -pkgpath gno.land/r/test/victim -func GetResult -gas-fee 1000000ugnot -gas-wanted 10000000 -broadcast -chainid=tendermint_test deployer
stdout 'rejected'

-- victim/gnomod.toml --
module = "gno.land/r/test/victim"
gno = "0.9"

-- victim/victim.gno --
package victim

import "chain/runtime"

var (
	admin     address
	yesVotes  int
	noVotes   int
	finalized bool
)

func init() {
	admin = address(runtime.OriginCaller())
	yesVotes = 10
	noVotes = 90
	finalized = true
}

// SetAdmin: non-crossing, should panic if called cross-realm.
func SetAdmin(newAdmin address) {
	admin = newAdmin
}

func GetAdmin(cur realm) address {
	return admin
}

// SetVotes: non-crossing, should panic if called cross-realm.
func SetVotes(yes, no int) {
	yesVotes = yes
	noVotes = no
}

func GetResult(cur realm) string {
	if !finalized {
		return "pending"
	}
	if yesVotes > noVotes {
		return "approved"
	}
	return "rejected"
}

-- exploit/exploit.gno --
package main

import "gno.land/r/test/victim"

func main() {
	// Corrupt admin to a dead address.
	func() {
		defer func() { _ = recover() }()
		victim.SetAdmin(address("g1deaddeaddeaddeaddeaddeaddeaddeaddead0000"))
	}()

	// Corrupt vote tally.
	func() {
		defer func() { _ = recover() }()
		victim.SetVotes(99, 1)
	}()

	// Verify corruption is visible within this tx.
	admin := victim.GetAdmin(cross)
	println("admin corrupted in-tx:", admin == address("g1deaddeaddeaddeaddeaddeaddeaddeaddead0000"))

	result := victim.GetResult(cross)
	println("vote corrupted in-tx:", result == "approved")

	println("corruption done")
}
