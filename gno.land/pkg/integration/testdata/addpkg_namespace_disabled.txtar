# When sysnames_pkgpath is not set (the default), namespace enforcement
# is disabled and any user can deploy packages to any namespace.

adduser gui

gnoland start

# give gui user more tokens
gnokey maketx send -send 1000000000ugnot -to $gui_user_addr -gas-fee 1000000ugnot -gas-wanted 10000000 -broadcast -chainid tendermint_test test1

# Gui can deploy to another user's address namespace (no enforcement)
gnokey maketx addpkg -pkgdir $WORK -pkgpath gno.land/r/$test1_user_addr/mysuperpkg -gas-fee 1000000ugnot -gas-wanted 10000000 -broadcast -chainid=tendermint_test gui
stdout 'OK!'

# Gui can deploy to a random namespace (no enforcement)
gnokey maketx addpkg -pkgdir $WORK/two -pkgpath gno.land/r/randomname/mysuperpkg -gas-fee 1000000ugnot -gas-wanted 10000000 -broadcast -chainid=tendermint_test gui
stdout 'OK!'

# Gui can deploy to its own address namespace
gnokey maketx addpkg -pkgdir $WORK/three -pkgpath gno.land/r/$gui_user_addr/mypkg -gas-fee 1000000ugnot -gas-wanted 10000000 -broadcast -chainid=tendermint_test gui
stdout 'OK!'

-- gnomod.toml --
module = "gno.land/r/mypkg"
gno = "0.9"

-- one.gno --
package one

func Render(path string) string {
    return "# Hello One"
}

-- two/gnomod.toml --
module = "gno.land/r/mypkg2"
gno = "0.9"

-- two/one.gno --
package one

func Render(path string) string {
    return "# Hello Two"
}

-- three/gnomod.toml --
module = "gno.land/r/mypkg3"
gno = "0.9"

-- three/one.gno --
package one

func Render(path string) string {
    return "# Hello Three"
}
