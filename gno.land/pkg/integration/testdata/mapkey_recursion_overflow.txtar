# Validate NEWTENDG-93: bounded recursion in ComputeMapKey protects against chain halt.
#
# ComputeMapKey (values.go) recurses once per nesting level when a
# composite value (array or struct) is used as a map key.  Without a
# depth limit, a sufficiently deep [1]any{...} chain exhausts the
# goroutine's Go-stack limit with a fatal error: stack overflow.
# Because GnoVM execution is deterministic, every validator crashes on
# the same block – chain halt.
#
# The fix adds a depth guard at maxComputeMapKeyDepth = 10 000.
# When the limit is exceeded the VM panics with a recoverable error
# string; the transaction framework catches it and returns a normal
# error to the caller – the node stays alive.
#
# Part 1 – shallow depth (9 999 levels): succeeds, confirming the
#           recursive code path is active and the guard is not
#           triggered prematurely.
#
# Part 2 – deep depth (15 000 levels): exceeds maxComputeMapKeyDepth;
#           the depth guard fires and returns a recoverable error.
#           The node stays alive and gnokey receives a structured error.

gnoland start

# ------------------------------------------------------------------
# Part 1: shallow depth – map key on a 9 999-level nested array.
# Verifies [1]any{...} chains are valid map keys and that the
# depth guard does not fire below the threshold.
# ------------------------------------------------------------------
gnokey maketx run -max-deposit 2000000000ugnot -gas-fee 10000000ugnot -gas-wanted 2000000000 -broadcast -chainid=tendermint_test test1 $WORK/shallow.gno
stdout 'OK!'

# ------------------------------------------------------------------
# Part 2: deep depth (15 000 levels) – exceeds maxComputeMapKeyDepth.
# The depth guard fires; the transaction returns an error.
# The node process stays alive (no fatal stack overflow).
# ------------------------------------------------------------------
! gnokey maketx run -max-deposit 2000000000ugnot -gas-fee 10000000ugnot -gas-wanted 2000000000 -broadcast -chainid=tendermint_test test1 $WORK/attack.gno
stderr 'map key nesting depth limit exceeded'

-- shallow.gno --
package main

// 9 999 levels of [1]any nesting used as a map key.
// Exercises ComputeMapKey (values.go) recursively 9 999 times.
// The depth guard fires at 10 000, so this should succeed.
func main() {
	var a any
	a = [1]int{0}
	for i := 0; i < 9999; i++ {
		a = [1]any{a}
	}
	m := make(map[any]int)
	m[a] = 1
	println(m[a])
}

-- attack.gno --
package main

// 15 000 levels of [1]any nesting.
// Exceeds maxComputeMapKeyDepth (10 000); the depth guard fires
// and the VM panics with "map key nesting depth limit exceeded".
// The transaction framework catches the panic and returns a normal
// error – the node process stays alive.
func main() {
	var a any
	a = [1]int{0}
	for i := 0; i < 15000; i++ {
		a = [1]any{a}
	}
	m := make(map[any]int)
	m[a] = 1
	println(m[a])
}
