# Restore-path gas asymmetry regression test for
# https://github.com/gnolang/gno/pull/5127 follow-up.
#
# Setup: init() persists 5 map entries during genesis, so by the time the
# first user tx runs, the realm's `stored` map already exists on disk and
# its in-memory vmap is empty (per-tx cacheObjects is fresh).
#
# Tx1 (Insert): first access to `stored` cold-loads the map →
# fillTypesOfValue → ComputeMapKey on each of the 5 persisted entries
# (restore path), then writes 1 new entry (write path). So Tx1 already
# exercises both paths.
#
# Tx2 (Lookup, fresh tx): cacheObjects reset, so the map is cold-loaded
# again — ComputeMapKey runs for all 6 entries (5 + Tx1's add) on the
# restore path. No write.
#
# Under #5127 the restore path passed a nil *Machine to ComputeMapKey and
# charged ZERO gas — the asymmetry this follow-up closes. Post-follow-up,
# ComputeMapKey reaches the meter via store.GetMeter() so write and
# restore paths pay symmetrically.
#
# The pinned GAS USED values are calibration goldens. Removing the
# restore-path charge drops Tx1 by 5*per-entry and Tx2 by 6*per-entry —
# both pins will fail. Empirically the per-entry restore charge is ~788
# gas for this bigKey shape; a regression to the pre-follow-up asymmetry
# would shift Tx1 by ~3940 and Tx2 by ~4728.

loadpkg gno.land/r/demo/mapgas $WORK

gnoland start

# Tx1: cold-loads `stored` (5 entries from init() → restore path) then
# writes 1 entry → ComputeMapKey runs on both paths in this tx.
gnokey maketx call -pkgpath gno.land/r/demo/mapgas -func Insert -gas-fee 360001ugnot -gas-wanted 3_600_000 -chainid=tendermint_test test1
stdout 'GAS USED:\s+2595329'

# Tx2: fresh tx; cacheObjects is empty per-tx (BeginTransaction allocates a
# new map), so accessing `stored` triggers loadObjectSafe →
# fillTypesOfValue → ComputeMapKey on all 6 entries via the restore path.
# No write.
#
# REGRESSION SIGNAL: removing the restore-path charge drops both pins —
# Tx1 by 5*per-entry, Tx2 by 6*per-entry. A revert of the follow-up's
# Store.GetMeter() routing inside ComputeMapKey would manifest exactly
# that way.
gnokey maketx call -pkgpath gno.land/r/demo/mapgas -func Lookup -args 7 -gas-fee 360001ugnot -gas-wanted 3_600_000 -chainid=tendermint_test test1
stdout 'GAS USED:\s+1861974'
stdout '"seven" string'

-- gnomod.toml --
module = "gno.land/r/demo/mapgas"
gno = "0.9"

-- mapgas.gno --
package mapgas

// Big enough that vmap-rebuild cost per entry is observable above the
// I/O + amino-decode noise floor when the realm is restored cold.
type bigKey struct {
	A, B, C, D, E, F, G, H int64
}

var stored = make(map[bigKey]string)

func init() {
	// Pre-populate so the realm has a non-trivial map persisted on disk
	// before the first user-facing tx runs.
	stored[bigKey{A: 1}] = "one"
	stored[bigKey{A: 3}] = "three"
	stored[bigKey{A: 5}] = "five"
	stored[bigKey{A: 7}] = "seven"
	stored[bigKey{A: 9}] = "nine"
}

// Insert adds one more entry. In a fresh tx the first access to `stored`
// cold-loads it (restore path) before the write itself, so this exercises
// ComputeMapKey on both paths.
func Insert(cur realm) {
	stored[bigKey{A: 11, B: 13, C: 17}] = "primes"
}

// Lookup reads a value by key. In a fresh tx, the first access forces
// rehydration of `stored` from disk, which (post-follow-up) charges
// ComputeMapKey on the restore path.
func Lookup(cur realm, k int64) string {
	return stored[bigKey{A: k}]
}
