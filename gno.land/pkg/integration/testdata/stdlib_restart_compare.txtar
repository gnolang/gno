# Test that gas is identical for restart vs no-restart given the same state.
# Both Convert calls start from lastResult="42" and set it to "42".
# EXACT_GAS is the expected GAS USED — both calls must match exactly.

env ADDPKG_GAS=4_800_000
env SETUP_GAS=3_200_000
env EXACT_GAS=1974482

gnoland start

gnokey maketx addpkg -pkgdir $WORK/myrealm -pkgpath gno.land/r/test/myrealm -gas-fee 1000001ugnot -gas-wanted $ADDPKG_GAS -broadcast -chainid=tendermint_test test1
stdout OK!

# Set lastResult="42" (setup — gas not checked).
gnokey maketx call -pkgpath gno.land/r/test/myrealm -func Convert -args '42' -gas-fee 1000001ugnot -gas-wanted $SETUP_GAS -broadcast -chainid=tendermint_test test1
stdout OK!

# No restart. lastResult="42" -> "42". Must match EXACT_GAS.
gnokey maketx call -pkgpath gno.land/r/test/myrealm -func Convert -args '42' -gas-fee 1000001ugnot -gas-wanted $SETUP_GAS -broadcast -chainid=tendermint_test test1
stdout 'GAS USED:\s+'${EXACT_GAS}

gnoland restart

# After restart. lastResult="42" -> "42". Must match same EXACT_GAS.
gnokey maketx call -pkgpath gno.land/r/test/myrealm -func Convert -args '42' -gas-fee 1000001ugnot -gas-wanted $SETUP_GAS -broadcast -chainid=tendermint_test test1
stdout 'GAS USED:\s+'${EXACT_GAS}

-- myrealm/gnomod.toml --
module = "gno.land/r/test/myrealm"
gno = "0.9"

-- myrealm/myrealm.gno --
package myrealm

import (
	"strconv"
	"strings"
)

var lastResult string

var replacer = strings.NewReplacer("a", "b")

func Convert(cur realm, n int) string {
	lastResult = strconv.Itoa(n)
	lastResult = replacer.Replace(lastResult)
	return lastResult
}
